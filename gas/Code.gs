const SHEET_NAME='ranking';
const HEADERS=['created_at','name','score','floor','level','gold','defeated','turn','cleared','dungeon_id','dungeon_name','version'];
function doGet(e){const action=(e.parameter.action||'ranking').toLowerCase();const callback=e.parameter.callback||'';let result;if(action==='ranking'){result={ok:true,ranking:getRanking_(String(e.parameter.dungeonId||''),Number(e.parameter.limit||10))}}else result={ok:false,error:'unknown action'};const json=JSON.stringify(result);if(callback)return ContentService.createTextOutput(`${callback}(${json});`).setMimeType(ContentService.MimeType.JAVASCRIPT);return ContentService.createTextOutput(json).setMimeType(ContentService.MimeType.JSON)}
function doPost(e){const p=e.parameter||{},sh=getSheet_();ensureHeaders_(sh);const row={created_at:new Date(),name:sanitize_(p.name||'名無し'),score:num_(p.score),floor:num_(p.floor),level:num_(p.level),gold:num_(p.gold),defeated:num_(p.defeated),turn:num_(p.turn),cleared:String(p.cleared)==='true',dungeon_id:sanitize_(p.dungeonId||'beginner'),dungeon_name:sanitize_(p.dungeonName||''),version:sanitize_(p.version||'')};sh.appendRow(HEADERS.map(h=>row[h]));return ContentService.createTextOutput(JSON.stringify({ok:true})).setMimeType(ContentService.MimeType.JSON)}
function getRanking_(dungeonId,limit){const sh=getSheet_();ensureHeaders_(sh);const v=sh.getDataRange().getValues();if(v.length<=1)return[];const h=v[0].map(String),idx={};h.forEach((x,i)=>idx[x]=i);return v.slice(1).map(r=>({createdAt:r[idx.created_at],name:r[idx.name],score:Number(r[idx.score]||0),floor:Number(r[idx.floor]||0),level:Number(r[idx.level]||0),gold:Number(r[idx.gold]||0),defeated:Number(r[idx.defeated]||0),turn:Number(r[idx.turn]||0),cleared:r[idx.cleared]===true,dungeonId:r[idx.dungeon_id]||'beginner',dungeonName:r[idx.dungeon_name]||'',version:r[idx.version]||''})).filter(r=>!dungeonId||r.dungeonId===dungeonId).sort((a,b)=>b.score-a.score).slice(0,Math.max(1,Math.min(limit||10,50)))}
function getSheet_(){const ss=SpreadsheetApp.getActiveSpreadsheet();let sh=ss.getSheetByName(SHEET_NAME);if(!sh)sh=ss.insertSheet(SHEET_NAME);ensureHeaders_(sh);return sh}
function ensureHeaders_(sh){if(sh.getLastRow()===0){sh.appendRow(HEADERS);sh.setFrozenRows(1);return}const cur=sh.getRange(1,1,1,Math.max(1,sh.getLastColumn())).getValues()[0].map(String);HEADERS.filter(h=>!cur.includes(h)).forEach(h=>sh.getRange(1,sh.getLastColumn()+1).setValue(h));sh.setFrozenRows(1)}
function sanitize_(v){return String(v||'').replace(/[<>"'&]/g,'').slice(0,80)}function num_(v){const n=Number(v);return Number.isFinite(n)?n:0}
